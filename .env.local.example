# ============================================
# BistAI — Environment Variables Template
# ============================================
# Bu dosyayi .env.local olarak kopyala ve degerleri doldur:
#   cp .env.local.example .env.local

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Anthropic (AI aciklamalar) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- FRED API (ABD makro verileri) ---
FRED_API_KEY=your_fred_api_key
FRED_TIMEOUT_MS=10000
FRED_MAX_RETRIES=2

# --- TCMB (Turkiye makro verileri) ---
TCMB_API_KEY=your_tcmb_api_key

# --- Stripe (Odeme sistemi — Phase 11) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIUM=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Site URL ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- AlphaVantage (Phase 13 — yedek veri + fundamentals) ---
# Ucretsiz key: alphavantage.co/support/#api-key (25 istek/gun)
ALPHAVANTAGE_API_KEY=your_alphavantage_key

# --- ML Servisi (Phase 13 — Python FastAPI + XGBoost) ---
# Railway/Render deploy sonrasi URL
# Yoksa otomatik heuristic fallback devreye girer
ML_SERVICE_URL=https://bistai-ml.railway.app
